#For this project, I used SQL to query the Superstore database to get information about items sold at the store and their prices.

#Use a SELECT statement to order the items by price.
SELECT item_name, price
FROM superstore
ORDER BY price ASC;

#Write a query to show which category has the most purchases, from most to least
SELECT category
FROM superstore
WHERE category>=1
GROUP BY category
ORDER BY category DESC;

#Show the most expenisve purchase form each category.
SELECT item_name, category, price
FROM superstore
GROUP BY category
ORDER BY price DESC;

#Show which category had the highest average spending.
SELECT category, AVG(price)
FROM superstore
GROUP BY category
ORDER BY AVG(price) DESC;

#Show the average cost of kitchen supplies
SELECT category, AVG(price)
FROM superstore
WHERE category='Kitchen Supplies';

